{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DapperFlow",
  "version": "0.0.0",
  "identifier": "com.dappertoast.dapperflow",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DapperFlow",
        "width": 1320,
        "height": 860,
        "minWidth": 940,
        "minHeight": 600,
        "theme": "Dark",
        "backgroundColor": "#0E1116"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
